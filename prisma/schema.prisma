generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Stores Terminal Contact Form submissions
// Written by: POST /api/contact
model Contact {
  id        Int      @id @default(autoincrement())
  company   String
  email     String
  message   String
  createdAt DateTime @default(now())

  @@map("contacts")
}

// Reserved for v2 analytics — table exists, not written in v1
model Pageview {
  id        Int      @id @default(autoincrement())
  page      String
  device    String?
  country   String?
  createdAt DateTime @default(now())

  @@map("pageviews")
}

// Stores recruiter/operator interaction events for v2 console analytics
model OperatorEvent {
  id        Int      @id @default(autoincrement())
  type      String
  detail    String?
  page      String?
  device    String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@map("operator_events")
}

// Stores Oracle Kitchen skill interaction analytics
model SkillClick {
  id        Int      @id @default(autoincrement())
  nodeId    String
  skill     String
  device    String?
  createdAt DateTime @default(now())

  @@map("skill_clicks")
}

// Stores anonymous UI preferences such as audio toggle state
model UserPreference {
  id           Int      @id @default(autoincrement())
  clientId     String   @unique
  audioEnabled Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("user_preferences")
}
